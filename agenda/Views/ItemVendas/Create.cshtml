@section Styles {
    <link rel="stylesheet" href="~/css/produtos.css" />
}

@model agenda.Models.ItemVenda

@{
    ViewData["Title"] = "Create";
    Layout = "_Layout";
}

<h1>Novo Item de Venda</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Id_Agenda" class="control-label">Cliente</label>
                <select asp-for="Id_Agenda" class="form-control" asp-items="ViewBag.Clientes">
                    <option value="">-- Selecione o cliente --</option>
                </select>
                <span asp-validation-for="Id_Agenda" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Id_Produto" class="control-label">Produto</label>
                <select asp-for="Id_Produto" id="selectProduto" class="form-control" asp-items="ViewBag.Produtos">
                    <option value="">-- Selecione o produto --</option>
                </select>
                <span asp-validation-for="Id_Produto" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Nome do Produto</label>
                <input id="nomeProdutoDisplay" class="form-control" readonly placeholder="Preenchido automaticamente" />
            </div>

            {{-- campos hidden que vão pro servidor --}}
            <input type="hidden" asp-for="NomeProduto" id="nomeProdutoHidden" />
            <input type="hidden" asp-for="NomeCliente" />

            <div class="form-group">
                <label asp-for="Quantidade" class="control-label"></label>
                <input asp-for="Quantidade" class="form-control" />
                <span asp-validation-for="Quantidade" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Data" class="control-label"></label>
                <input asp-for="Data" class="form-control" type="datetime-local" />
                <span asp-validation-for="Data" class="text-danger"></span>
            </div>

            <div class="form-group mt-2">
                <input type="submit" value="Criar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar à Lista</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById('selectProduto').addEventListener('change', function () {
            const id = this.value;
            if (!id) {
                document.getElementById('nomeProdutoDisplay').value = '';
                document.getElementById('nomeProdutoHidden').value = '';
                return;
            }
            fetch('/ItemVendas/GetProduto/' + id)
                .then(r => r.json())
                .then(data => {
                    document.getElementById('nomeProdutoDisplay').value = data.nome;
                    document.getElementById('nomeProdutoHidden').value = data.nome;
                });
        });
    </script>
}